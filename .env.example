# Copy this file to .env and fill in your values.
# .env is git-ignored and never committed.

# JWT secret — generate a long random string for production
SECRET_KEY=change-me-to-a-random-secret-at-least-32-chars

# MongoDB connection (docker-compose default: internal mongo service)
MONGO_URL=mongodb://mongo:27017
DB_NAME=mayajal

# AI provider: gemini | openai | anthropic | heuristic
AI_PROVIDER=heuristic

# API keys — only fill in the provider you chose above
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# RapidAPI key (optional — enables RapidAPI Instagram scraper fallback)
RAPIDAPI_KEY=

# Instagram credentials (optional — enables instagrapi profile fetch)
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=
INSTAGRAM_SESSION_ID=

# Local Instagram proxy URL (optional — for Docker local dev only)
INSTAGRAM_PROXY_URL=

# Frontend API URL (used by frontend docker service)
REACT_APP_API_URL=http://localhost:8000
