{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "startCommand": "/bin/sh -c 'uvicorn app.main:app --host 0.0.0.0 --port $PORT'",
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE"
  }
}
