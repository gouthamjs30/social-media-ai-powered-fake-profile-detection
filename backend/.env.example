# MAYAJAL Backend — Local development configuration
# Copy to .env and fill in your values. Never commit .env.

# MongoDB
MONGO_URL=mongodb://localhost:27017
DB_NAME=mayajal

# JWT Secret — use a long random string in production
SECRET_KEY=change-me-to-a-random-secret-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# AI Provider: gemini | openai | anthropic | heuristic
AI_PROVIDER=heuristic

# API Keys — only fill in the provider you use
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# RapidAPI key (optional)
RAPIDAPI_KEY=

# Instagram credentials (optional — for instagrapi profile fetching)
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=
INSTAGRAM_SESSION_ID=
INSTAGRAM_PROXY_URL=
